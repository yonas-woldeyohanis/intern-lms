# ============================================================
# BMVEI Library Management System - Backend Environment Config
# Copy this file to .env and fill in real values. NEVER commit .env
# ============================================================

# Server
NODE_ENV=development
PORT=5000
API_BASE_PATH=/api/v1
CLIENT_URL=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bmvei_lms
DB_USER=bmvei_app
DB_PASSWORD=change_me_strong_password
DB_CONNECTION_LIMIT=10

# JWT
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password / Account security
BCRYPT_SALT_ROUNDS=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# File uploads
MAX_UPLOAD_MB=5
UPLOAD_DIR=uploads

# Seed script (used only by `npm run seed`, not read at normal runtime)
ADMIN_DEFAULT_EMAIL=admin@bmvei.local
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe@12345

# Logging
LOG_LEVEL=info
